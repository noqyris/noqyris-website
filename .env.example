# Contact form email delivery (Resend — https://resend.com)
#
# The /start intake form POSTs to /api/contact, which (1) emails the brief to
# the studio inbox and (2) sends the visitor an automatic acknowledgement.
# WITHOUT RESEND_API_KEY the form gracefully falls back to opening the visitor's
# own mail client (mailto) — so it always works, even unconfigured.
#
# Set these in .env.local for local dev, and in the Vercel project's
# Environment Variables for production. Senders must be on a domain verified in
# Resend; they need not be real mailboxes (replies are routed via reply-to).

# Resend API key — Resend dashboard → API Keys. Required for server-side send.
RESEND_API_KEY=

# Where leads land (your inbox). Optional; defaults to site.email.
CONTACT_TO=team@noqyris.com

# Sender of the LEAD email (the one that comes to you). Reply-to is the visitor,
# so you reply straight to the lead. Leave blank before the domain is verified
# to use Resend's test sender (delivers only to your Resend account email).
CONTACT_FROM="noqyris <hello@noqyris.com>"

# Sender of the ACKNOWLEDGEMENT email (sent to the visitor). Reply-to is
# CONTACT_TO, so the visitor's reply reaches you. Optional; falls back to
# CONTACT_FROM if unset.
CONTACT_ACK_FROM="noqyris <team@noqyris.com>"
